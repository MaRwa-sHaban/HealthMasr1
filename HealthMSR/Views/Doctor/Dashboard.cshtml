@model HealthMSR.ViewModels.DoctorDashboardViewModel
@using HealthMSR.DAL.Enums
@inject HealthMSR.DAL.AppDbContext _db
@* @model HealthMSR.ViewModels.DoctorDashboardViewModel *@
@* @using HealthMSR.Enums *@
@using HealthMSR.DAL
@{
    ViewData["Title"] = "Doctor Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var d = Model.Doctor;
}

<div class="dashboard-wrap">

    <!-- SIDEBAR -->
    <aside class="sidebar">
        <div class="sidebar-logo">
            <span class="logo-part1">Health</span><span class="logo-part2">MSR</span>
        </div>

        <div class="sidebar-profile">
            <div class="profile-avatar">@d.FullName[0]</div>
            <div class="profile-name">Dr. @d.FullName</div>
            <div class="profile-role">@d.Specialty</div>
            <div class="profile-id">@d.LicenseNumber</div>
        </div>

        <nav class="sidebar-nav">
            <a href="@Url.Action("Dashboard", "Doctor", new { section = "overview" })"
               class="nav-item @(Model.ActiveSection == "overview" ? "active" : "")">Overview</a>
            <a href="@Url.Action("Dashboard", "Doctor", new { section = "search" })"
               class="nav-item @(Model.ActiveSection == "search" ? "active" : "")">Search Patient</a>
            <a href="@Url.Action("Dashboard", "Doctor", new { section = "profile" })"
               class="nav-item @(Model.ActiveSection == "profile" ? "active" : "")">My Profile</a>
        </nav>

        <a href="@Url.Action("Logout", "Auth")" class="logout-btn">Logout</a>
    </aside>

    <!-- MAIN -->
    <main class="main-content">
        <div class="topbar">
            <h2 class="page-title">
                @if (Model.ActiveSection == "overview") { <text>Welcome, Dr. @d.FullName</text> }
                @if (Model.ActiveSection == "search") { <text>Search Patient</text> }
                @if (Model.ActiveSection == "profile") { <text>My Profile</text> }
            </h2>
        </div>

        <div class="page-content">

            @* OVERVIEW *@
            @if (Model.ActiveSection == "overview")
            {
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-icon blue">👥</div>
                        <div class="stat-info">
                            <span class="stat-num">@Model.TodayPatients</span>
                            <span class="stat-label">Patients Today</span>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon green">💊</div>
                        <div class="stat-info">
                            <span class="stat-num">@Model.TodayPrescriptions</span>
                            <span class="stat-label">Prescriptions</span>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon purple">🧪</div>
                        <div class="stat-info">
                            <span class="stat-num">@Model.TodayLabRequests</span>
                            <span class="stat-label">Lab Requests</span>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon orange">🩻</div>
                        <div class="stat-info">
                            <span class="stat-num">@Model.TodayRadRequests</span>
                            <span class="stat-label">Rad Requests</span>
                        </div>
                    </div>
                </div>

                <div class="section-card">
                    <div class="empty-state">
                        <div class="empty-icon">🔍</div>
                        <p>Search for a patient to start a session</p>
                        <a href="@Url.Action("Dashboard", "Doctor", new { section = "search" })"
                           class="btn-primary" style="display:inline-block; width:auto; padding:12px 28px; margin-top:16px; text-decoration:none;">
                            Search Patient
                        </a>
                    </div>
                </div>
            }

            @if (Model.ActiveSection == "search")
            {
                <div class="section-card">
                    <h3 class="section-heading">Search by National ID</h3>
                    <form method="get" asp-action="Dashboard" asp-controller="Doctor"
                          style="display:flex; gap:12px;" id="searchForm">
                        <input type="hidden" name="section" value="search" />
                        <div style="flex:1; position:relative;">
                            <input type="text" name="searchId" id="searchInput"
                                   placeholder="Enter 14-digit National ID"
                                   maxlength="14"
                                   oninput="validateNID(this)"
                                   style="width:100%; padding:14px 18px; border-radius:12px; border:2px solid var(--border); font-size:1rem; outline:none; background:#f8fafc;" />
                            <div id="nidError"
                                 style="display:none; color:#ef4444; font-size:0.82rem; font-weight:500; margin-top:6px; padding:8px 12px; background:#fff5f5; border-radius:8px; border:1px solid #fecaca;">
                                ⚠️ National ID must be exactly 14 digits
                            </div>
                        </div>
                        <button type="submit" class="btn-primary" style="width:auto; padding:14px 28px;"
                                onclick="return checkNID()">
                            Search
                        </button>
                    </form>

                    @if (!string.IsNullOrEmpty(Model.SearchError))
                    {
                        <div class="error-msg" style="margin-top:12px;">@Model.SearchError</div>
                    }
                </div>

                @if (Model.SearchedPatient != null)
                {
                    var pat = Model.SearchedPatient;
                    var patAge = DateTime.Now.Year - pat.DateOfBirth.Year;

                    <!-- Patient Header — اسمه قابل للضغط -->
                    <div style="background:linear-gradient(135deg,#0f172a,#0369a1); border-radius:18px; padding:24px; display:flex; align-items:center; gap:20px; margin-bottom:20px; box-shadow:0 8px 32px rgba(14,165,233,0.2);">
                        <div class="profile-avatar" style="width:72px; height:72px; font-size:2.2rem; border:3px solid rgba(255,255,255,0.3);">
                            @pat.FirstName[0]
                        </div>
                        <div style="flex:1;">
                            <a href="@Url.Action("PatientProfile", "Doctor", new { patientId = pat.PatientId })"
                                   style="font-family:'Cormorant Garamond',serif; font-size:1.8rem; color:white; font-weight:600; text-decoration:none; display:block; margin-bottom:8px; transition:0.2s;"
                                   onmouseover="this.style.color='#38bdf8'" onmouseout="this.style.color='white'">
                                @pat.FirstName @pat.LastName ↗
                            </a>
                            <div style="display:flex; gap:10px; flex-wrap:wrap;">
                                <span style="background:rgba(255,255,255,0.15); color:#e0f2fe; padding:4px 12px; border-radius:20px; font-size:0.82rem;">@pat.NationalId</span>
                                <span style="background:rgba(255,255,255,0.15); color:#e0f2fe; padding:4px 12px; border-radius:20px; font-size:0.82rem;">@(pat.MedicalRecord?.BloodType ?? "—")</span>
                                <span style="background:rgba(255,255,255,0.15); color:#e0f2fe; padding:4px 12px; border-radius:20px; font-size:0.82rem;">@patAge yrs</span>
                            </div>
                        </div>
                    </div>

                    <!-- Tabs -->
                    <!-- Vital Signs Button -->
                    <div style="display:flex; gap:8px; margin-bottom:20px; flex-wrap:wrap;">
                        @foreach (var tab in new[] { "diagnosis", "vitals", "prescription", "lab", "radiology", "history" })
                        {
                            <a href="#" onclick="showTab('@tab'); return false;"
                                   class="tab-btn" id="tab-@tab"
                                   style="padding:10px 20px; border-radius:12px; border:2px solid var(--border); background:var(--white); color:var(--gray); font-weight:600; cursor:pointer; text-decoration:none; transition:0.25s; display:inline-block;">
                                @(tab == "diagnosis" ? "Add Diagnosis" :
                                 tab == "vitals" ? "Vital Signs" :
                                  tab == "prescription" ? "Prescription" :
                                  tab == "lab" ? "Lab Request" :
                                  tab == "radiology" ? "Radiology Request" : "Full History")
                            </a>

                        }
                    </div>

                    <!-- DIAGNOSIS TAB -->
                    <div id="content-diagnosis" class="tab-content section-card">
                        <h3 class="section-heading">Add Diagnosis</h3>

                        @* آخر تشخيص *@
                        @if (Model.PatientEncounters.Any())
                        {
                            var lastEnc = Model.PatientEncounters.First();
                            <div style="background:var(--teal-light); border-radius:12px; padding:14px 18px; margin-bottom:20px; border-left:4px solid var(--teal); display:flex; justify-content:space-between; align-items:center;">
                                <div>
                                    <span style="font-size:0.78rem; font-weight:700; color:var(--teal-dark);">Last Diagnosis:</span>
                                    <span style="font-family:'Cormorant Garamond',serif; font-size:1rem; color:var(--dark); margin-left:8px;">@lastEnc.Status</span>
                                </div>
                                <span style="font-size:0.78rem; color:var(--gray);">@lastEnc.StartTime.ToString("yyyy-MM-dd")</span>
                            </div>
                        }

                        <form asp-action="AddEncounter" asp-controller="Doctor" method="post">
                            <input type="hidden" name="patientId" value="@pat.PatientId" />
                            <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:16px;">
                                <div class="input-group">
                                    <label>Diagnosis</label>
                                    <input type="text" name="status" placeholder="e.g. Hypertension..." required />
                                </div>
                                <div class="input-group">
                                    <label>Date & Time</label>
                                    <input type="datetime-local" name="startTime" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
                                </div>
                                <div class="input-group" style="grid-column:span 2;">
                                    <label>Notes</label>
                                    <textarea name="notes" placeholder="Additional notes..." rows="3"
                                              style="padding:13px 16px; border-radius:12px; border:2px solid var(--border); font-size:0.95rem; outline:none; width:100%; resize:vertical; font-family:'Plus Jakarta Sans',sans-serif;"></textarea>
                                </div>
                            </div>
                            <button type="submit" class="btn-primary" style="width:auto; padding:12px 28px;">Save Diagnosis</button>
                        </form>
                    </div>

                    <!-- PRESCRIPTION TAB -->
                    <div id="content-prescription" class="tab-content section-card" style="display:none;">
                        <h3 class="section-heading">Write Prescription</h3>

                        @if (Model.PatientEncounters.Any())
                        {
                            var lastEnc = Model.PatientEncounters.First();

                            @* آخر تشخيص *@
                            <div style="background:var(--teal-light); border-radius:12px; padding:14px 18px; margin-bottom:12px; border-left:4px solid var(--teal); display:flex; justify-content:space-between;">
                                <div>
                                    <span style="font-size:0.78rem; font-weight:700; color:var(--teal-dark);">Last Diagnosis:</span>
                                    <span style="font-family:'Cormorant Garamond',serif; font-size:1rem; color:var(--dark); margin-left:8px;">@lastEnc.Status</span>
                                </div>
                                <span style="font-size:0.78rem; color:var(--gray);">@lastEnc.StartTime.ToString("yyyy-MM-dd")</span>
                            </div>

                            @* آخر روشتة *@
                            @if (Model.PatientPrescriptions.Any())
                            {
                                var lastRx = Model.PatientPrescriptions.First();
                                <div style="background:#f0fdf4; border-radius:12px; padding:14px 18px; margin-bottom:20px; border-left:4px solid #10b981;">
                                    <span style="font-size:0.78rem; font-weight:700; color:#065f46;">Last Prescription (@lastRx.DatePrescribed.ToString("yyyy-MM-dd")):</span>
                                    <div style="display:flex; flex-wrap:wrap; gap:6px; margin-top:8px;">
                                        @foreach (var item in lastRx.Items)
                                        {
                                            <span style="background:#d1fae5; color:#065f46; padding:3px 10px; border-radius:20px; font-size:0.78rem;">
                                                @item.Medication?.DrugName @item.Dosage
                                            </span>
                                        }
                                    </div>
                                </div>
                            }

                            <form asp-action="AddPrescription" asp-controller="Doctor" method="post">
                                <input type="hidden" name="patientId" value="@pat.PatientId" />
                                <input type="hidden" name="encounterId" value="@lastEnc.EncounterId" />

                                <div id="med-list">
                                    <div class="med-row" style="display:grid; grid-template-columns:2fr 1fr 1.5fr 1fr; gap:10px; margin-bottom:12px; padding-bottom:12px; border-bottom:1px solid var(--border);">
                                        <div class="input-group">
                                            <label>Medication Name</label>
                                            <input type="text" name="medicationIds[]" placeholder="e.g. Amoxicillin"
                                                   style="padding:12px 16px; border-radius:12px; border:2px solid var(--border); width:100%; font-size:0.95rem; outline:none;" />
                                        </div>
                                        <div class="input-group">
                                            <label>Dosage</label>
                                            <input type="text" name="dosages[]" placeholder="500mg"
                                                   style="padding:12px 16px; border-radius:12px; border:2px solid var(--border); width:100%; font-size:0.95rem; outline:none;" />
                                        </div>
                                        <div class="input-group">
                                            <label>Frequency</label>
                                            <select name="frequencies[]" id="freqSelect0"
                                                    onchange="checkCustomFreq(this)"
                                                    style="padding:12px 16px; border-radius:12px; border:2px solid var(--border); width:100%; font-size:0.95rem; outline:none; background:#f8fafc;">
                                                <option>Once daily</option>
                                                <option>Twice daily</option>
                                                <option>3 times daily</option>
                                                <option>Every 8 hours</option>
                                                <option>As needed</option>
                                                <option value="custom">Other (type below)</option>
                                            </select>
                                            <input type="text" class="custom-freq" placeholder="Type custom frequency..."
                                                   style="display:none; padding:12px 16px; border-radius:12px; border:2px solid var(--teal); width:100%; font-size:0.95rem; outline:none; margin-top:6px;" />
                                        </div>
                                        <div class="input-group">
                                            <label>Duration</label>
                                            <input type="text" name="durations[]" placeholder="7 days"
                                                   style="padding:12px 16px; border-radius:12px; border:2px solid var(--border); width:100%; font-size:0.95rem; outline:none;" />
                                        </div>
                                    </div>
                                </div>

                                <button type="button" onclick="addMedRow()"
                                        style="width:100%; padding:10px; border-radius:12px; border:2px dashed var(--teal); background:transparent; color:var(--teal-dark); font-weight:600; cursor:pointer; margin-bottom:16px; font-size:0.95rem;">
                                    + Add Another Medication
                                </button>

                                <div class="input-group" style="margin-bottom:16px;">
                                    <label>Notes</label>
                                    <input type="text" name="notes" placeholder="Additional notes..."
                                           style="padding:12px 16px; border-radius:12px; border:2px solid var(--border); width:100%; font-size:0.95rem; outline:none;" />
                                </div>

                                <button type="submit" class="btn-primary" style="width:auto; padding:12px 28px;">Save Prescription</button>
                            </form>
                        }
                        else
                        {
                            <div class="empty-state">
                                <div class="empty-icon">⚠️</div>
                                <p>Please add a diagnosis first</p>
                            </div>
                        }
                    </div>


                    <!-- LAB TAB -->
                    <div id="content-lab" class="tab-content section-card" style="display:none;">
                        <h3 class="section-heading">Lab Request</h3>

                        @* آخر تحاليل *@
                        @if (Model.PatientLabReports.Any())
                        {
                            var lastLab = Model.PatientLabReports.First();
                            <div style="background:#fef3c7; border-radius:12px; padding:14px 18px; margin-bottom:20px; border-left:4px solid #f59e0b;">
                                <span style="font-size:0.78rem; font-weight:700; color:#92400e;">Last Lab Request:</span>
                                <span style="font-family:'Cormorant Garamond',serif; font-size:1rem; color:var(--dark); margin-left:8px;">@lastLab.TestName</span>
                                <span style="font-size:0.78rem; color:var(--gray); margin-left:8px;">— @lastLab.Status</span>
                            </div>
                        }

                        @if (Model.PatientEncounters.Any())
                        {
                            <form asp-action="AddLabRequest" asp-controller="Doctor" method="post">
                                <input type="hidden" name="patientId" value="@pat.PatientId" />
                                <input type="hidden" name="encounterId" value="@Model.PatientEncounters.First().EncounterId" />
                                <div class="input-group" style="margin-bottom:16px;">
                                    <label>Test Name</label>
                                    <input type="text" name="testName" placeholder="e.g. CBC, Blood Sugar, Liver Function..."
                                           style="padding:12px 16px; border-radius:12px; border:2px solid var(--border); width:100%; font-size:0.95rem; outline:none;" />
                                </div>
                                <button type="submit" class="btn-primary" style="width:auto; padding:12px 28px;">Send Request</button>
                            </form>
                        }
                        else
                        {
                            <div class="empty-state"><p>Add a diagnosis first</p></div>
                        }

                        @if (Model.PatientLabReports.Any())
                        {
                            <div style="margin-top:24px; border-top:1px solid var(--border); padding-top:20px;">
                                <h4 style="font-family:'Cormorant Garamond',serif; font-size:1.2rem; color:var(--teal-dark); margin-bottom:16px;">Previous Labs</h4>
                                @foreach (var lab in Model.PatientLabReports)
                                {
                                    <div style="display:flex; align-items:center; gap:16px; padding:12px 16px; border-radius:12px; border:1px solid var(--border); margin-bottom:10px;">
                                        <div style="flex:1;">
                                            <div style="font-weight:600; color:var(--dark);">🧪 @lab.TestName</div>
                                            <div style="font-size:0.82rem; color:var(--gray);">@lab.Results</div>
                                        </div>
                                        <span class="status-badge @(lab.Status == LabStatus.Completed ? "completed" : "pending")">@lab.Status</span>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <!-- RADIOLOGY TAB -->
                    <div id="content-radiology" class="tab-content section-card" style="display:none;">
                        <h3 class="section-heading">Radiology Request</h3>

                        @* آخر أشعة *@
                        @if (Model.PatientRadReports.Any())
                        {
                            var lastRad = Model.PatientRadReports.First();
                            <div style="background:#fef3c7; border-radius:12px; padding:14px 18px; margin-bottom:20px; border-left:4px solid #f59e0b;">
                                <span style="font-size:0.78rem; font-weight:700; color:#92400e;">Last Scan:</span>
                                <span style="font-family:'Cormorant Garamond',serif; font-size:1rem; color:var(--dark); margin-left:8px;">@lastRad.ScanType</span>
                                <span style="font-size:0.78rem; color:var(--gray); margin-left:8px;">— @lastRad.Status</span>
                            </div>
                        }

                        @if (Model.PatientEncounters.Any())
                        {
                            <form asp-action="AddRadRequest" asp-controller="Doctor" method="post">
                                <input type="hidden" name="patientId" value="@pat.PatientId" />
                                <input type="hidden" name="encounterId" value="@Model.PatientEncounters.First().EncounterId" />
                                <div class="input-group" style="margin-bottom:16px;">
                                    <label>Scan Type</label>
                                    <input type="text" name="scanType" placeholder="e.g. Chest X-Ray, MRI Brain, CT Abdomen..."
                                           style="padding:12px 16px; border-radius:12px; border:2px solid var(--border); width:100%; font-size:0.95rem; outline:none;" />
                                </div>
                                <button type="submit" class="btn-primary" style="width:auto; padding:12px 28px;">Send Request</button>
                            </form>
                        }

                        @if (Model.PatientRadReports.Any())
                        {
                            <div style="margin-top:24px; border-top:1px solid var(--border); padding-top:20px;">
                                <h4 style="font-family:'Cormorant Garamond',serif; font-size:1.2rem; color:var(--teal-dark); margin-bottom:16px;">Previous Scans</h4>
                                @foreach (var rad in Model.PatientRadReports)
                                {
                                    <div style="display:flex; align-items:center; gap:16px; padding:12px 16px; border-radius:12px; border:1px solid var(--border); margin-bottom:10px;">
                                        <div style="flex:1;">
                                            <div style="font-weight:600; color:var(--dark);">🩻 @rad.ScanType</div>
                                            <div style="font-size:0.82rem; color:var(--gray);">@(rad.Result ?? "Pending")</div>
                                        </div>
                                        <span class="status-badge @(rad.Status == "Ready" ? "completed" : "pending")">@rad.Status</span>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                    <!-- VITALS TAB -->
                    <div id="content-vitals" class="tab-content section-card" style="display:none;">
                        <h3 class="section-heading">Record Vital Signs</h3>

                        @if (Model.PatientEncounters.Any())
                        {
                            <form asp-action="AddVitalSigns" asp-controller="Doctor" method="post">
                                <input type="hidden" name="patientId" value="@pat.PatientId" />
                                <input type="hidden" name="encounterId" value="@Model.PatientEncounters.First().EncounterId" />

                                <div style="display:grid; grid-template-columns:repeat(2,1fr); gap:16px; margin-bottom:20px;">
                                    <div class="input-group">
                                        <label>🩺 Blood Pressure</label>
                                        <input type="text" name="bp" placeholder="e.g. 120/80"
                                               style="padding:13px 16px; border-radius:12px; border:2px solid var(--border); font-size:0.95rem; outline:none; width:100%;" />
                                        <span style="font-size:0.75rem; color:var(--gray);">mmHg</span>
                                    </div>
                                    <div class="input-group">
                                        <label>🩸 Blood Sugar</label>
                                        <input type="text" name="sugar" placeholder="e.g. 110"
                                               style="padding:13px 16px; border-radius:12px; border:2px solid var(--border); font-size:0.95rem; outline:none; width:100%;" />
                                        <span style="font-size:0.75rem; color:var(--gray);">mg/dL</span>
                                    </div>
                                    <div class="input-group">
                                        <label>🌡️ Temperature</label>
                                        <input type="text" name="temp" placeholder="e.g. 37.2"
                                               style="padding:13px 16px; border-radius:12px; border:2px solid var(--border); font-size:0.95rem; outline:none; width:100%;" />
                                        <span style="font-size:0.75rem; color:var(--gray);">°C</span>
                                    </div>
                                    <div class="input-group">
                                        <label>❤️ Pulse</label>
                                        <input type="text" name="pulse" placeholder="e.g. 72"
                                               style="padding:13px 16px; border-radius:12px; border:2px solid var(--border); font-size:0.95rem; outline:none; width:100%;" />
                                        <span style="font-size:0.75rem; color:var(--gray);">bpm</span>
                                    </div>
                                </div>

                                <button type="submit" class="btn-primary" style="width:auto; padding:12px 28px;">
                                    Save Vital Signs
                                </button>
                            </form>

                            @if (Model.PatientObservations.Any())
                            {
                                <div style="margin-top:24px; border-top:1px solid var(--border); padding-top:20px;">
                                    <h4 style="font-family:'Cormorant Garamond',serif; font-size:1.2rem; color:var(--teal-dark); margin-bottom:16px;">Previous Vital Signs</h4>
                                    @foreach (var group in Model.PatientObservations.GroupBy(o => o.DateTime.Date).OrderByDescending(g => g.Key))
                                    {
                                        <div style="border:1px solid var(--border); border-radius:14px; padding:18px; margin-bottom:14px;">
                                            <div style="font-size:0.85rem; color:var(--gray); font-weight:600; margin-bottom:14px;">
                                                @group.Key.ToString("yyyy-MM-dd")
                                            </div>
                                            <div style="display:grid; grid-template-columns:repeat(2,1fr); gap:12px;">
                                                @foreach (var obs in group)
                                                {
                                                    <div style="background:var(--bg); border-radius:12px; padding:14px; border:1px solid var(--teal-light); display:flex; justify-content:space-between; align-items:center;">
                                                        <span style="font-size:0.82rem; color:var(--gray); font-weight:600;">@obs.Unit</span>
                                                        <span style="font-family:'Cormorant Garamond',serif; font-size:1.4rem; font-weight:600; color:var(--teal-dark);">@obs.Value</span>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        }
                        else
                        {
                            <div class="empty-state">
                                <div class="empty-icon">⚠️</div>
                                <p>Please add a diagnosis first</p>
                            </div>
                        }
                    </div>
                    <!-- HISTORY TAB -->
                    <div id="content-history" class="tab-content section-card" style="display:none;">
                        <h3 class="section-heading">Full Medical History</h3>
                        @if (!Model.PatientEncounters.Any())
                        {
                            <div class="empty-state">
                                <div class="empty-icon">📋</div>
                                <p>No records yet</p>
                            </div>
                        }
                        else
                        {
                            <div class="timeline">
                                @foreach (var enc in Model.PatientEncounters)
                                {
                                    <div class="timeline-item">
                                        <div class="timeline-dot"></div>
                                        <div class="timeline-body">
                                            <div class="timeline-date">@enc.StartTime.ToString("yyyy-MM-dd HH:mm")</div>
                                            <div class="timeline-title">@enc.Status</div>
                                            <span class="status-badge @(enc.Status == "Completed" ? "completed" : "pending")">@enc.Status</span>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            }

            @* PROFILE *@
            @if (Model.ActiveSection == "profile")
            {
                <div class="section-card" style="text-align:center;">
                    <div class="profile-avatar" style="width:100px; height:100px; font-size:3rem; margin:0 auto 16px; box-shadow:0 8px 24px rgba(14,165,233,0.3);">@d.FullName[0]</div>
                    <h2 style="font-family:'Cormorant Garamond',serif; font-size:2rem; color:var(--dark); margin-bottom:12px;">Dr. @d.FullName</h2>
                    <span class="status-badge completed">@d.Specialty</span>
                    <div style="display:grid; grid-template-columns:repeat(2,1fr); gap:16px; margin-top:28px; text-align:left;">
                        <div style="background:var(--bg); border-radius:12px; padding:16px 20px; border:1px solid var(--border);">
                            <span style="display:block; font-size:0.75rem; color:var(--teal-dark); font-weight:700; text-transform:uppercase; letter-spacing:1px; margin-bottom:6px;">License Number</span>
                            <span style="font-family:'Cormorant Garamond',serif; font-size:1.3rem; font-weight:600;">@d.LicenseNumber</span>
                        </div>
                        <div style="background:var(--bg); border-radius:12px; padding:16px 20px; border:1px solid var(--border);">
                            <span style="display:block; font-size:0.75rem; color:var(--teal-dark); font-weight:700; text-transform:uppercase; letter-spacing:1px; margin-bottom:6px;">Organization</span>
                            <span style="font-family:'Cormorant Garamond',serif; font-size:1.3rem; font-weight:600;">@(d.Organization?.Name ?? "—")</span>
                        </div>
                    </div>
                </div>
            }

        </div>
    </main>
</div>

@section Scripts {
    <script>
        function showTab(tabName) {
            document.querySelectorAll('.tab-content').forEach(el => el.style.display = 'none');
            document.querySelectorAll('.tab-btn').forEach(el => {
                el.style.background = 'var(--white)';
                el.style.color = 'var(--gray)';
                el.style.borderColor = 'var(--border)';
            });
            var content = document.getElementById('content-' + tabName);
            if (content) content.style.display = 'block';
            var btn = document.getElementById('tab-' + tabName);
            if (btn) {
                btn.style.background = 'var(--teal)';
                btn.style.color = 'white';
                btn.style.borderColor = 'var(--teal)';
            }
        }

        function addMedRow() {
            var list = document.getElementById('med-list');
            var row = list.querySelector('.med-row').cloneNode(true);
            row.querySelectorAll('input').forEach(i => i.value = '');
            list.appendChild(row);
        }

        function validateNID(input) {
            input.value = input.value.replace(/\D/g, '');
            var error = document.getElementById('nidError');
            if (input.value.length > 0 && input.value.length < 14) {
                error.style.display = 'block';
                error.textContent = '⚠️ National ID must be exactly 14 digits (' + input.value.length + '/14)';
            } else {
                error.style.display = 'none';
            }
        }

        function checkNID() {
            var input = document.getElementById('searchInput');
            var error = document.getElementById('nidError');
            if (!input) return true;
            if (input.value.length !== 14) {
                error.style.display = 'block';
                error.textContent = '⚠️ Please enter a complete 14-digit National ID';
                input.focus();
                return false;
            }
            return true;
        }

        document.addEventListener('DOMContentLoaded', function() {
            showTab('diagnosis');
        });
                function checkCustomFreq(select) {
            var customInput = select.nextElementSibling;
            if (select.value === 'custom') {
                customInput.style.display = 'block';
                customInput.name = select.name;
                select.name = '';
            } else {
                customInput.style.display = 'none';
                select.name = customInput.name || select.name;
                customInput.name = '';
            }
        }
    </script>

}