@model HealthMSR.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="auth-wrap">
    <div class="auth-card">

        <div style="text-align:center; margin-bottom:20px;">
            <span class="logo-part1">Health</span><span class="logo-part2">MSR</span>
        </div>

        <h2 class="auth-title">@(Model?.Role ?? "Login")</h2>
        <p class="auth-sub">Enter your credentials</p>

        @if (ViewBag.Error != null)
        {
            <div class="error-msg">@ViewBag.Error</div>
        }

        <form asp-action="Login" method="post">
            <input type="hidden" asp-for="Role" value="@ViewBag.Role" />

            <div class="input-group">
                <label>National ID</label>
                <input asp-for="NationalId" placeholder="Enter your National ID" maxlength="14" />
            </div>

            <div class="input-group">
                <label>Password</label>
                <input asp-for="Password" type="password" placeholder="Enter your password" />
            </div>

            <div style="text-align:right; margin-bottom:16px;">
                <a href="#" style="color:var(--teal-dark); font-size:0.85rem; font-weight:600;">Forgot Password?</a>
            </div>

            <button type="submit" class="btn-primary">Login</button>
        </form>

        <div class="auth-link">
            Don't have an account?
            <a href="@Url.Action("Register", "Auth")">Create Account</a>
        </div>

        <div style="margin-top:16px; text-align:center;">
            <a href="@Url.Action("Index", "Home")" style="color:var(--gray); font-size:0.85rem;">← Back</a>
        </div>
    </div>
</div>