<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HealthMSR</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Playball&family=Cormorant+Garamond:wght@500;600&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>
    @RenderBody()
    <button id="darkToggle" onclick="toggleDark()"
            style="position:fixed; bottom:24px; right:24px; width:48px; height:48px;
        border-radius:50%; border:2px solid var(--teal);
        background:transparent; cursor:pointer; font-size:1.3rem;
        z-index:9999; box-shadow:0 4px 20px rgba(14,165,233,0.15);
        transition:0.3s; display:flex; align-items:center; justify-content:center;">
        🌙
    </button>
    <!-- كل الـ Scripts هنا في الآخر -->
    <script src="~/js/healthmsr.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>