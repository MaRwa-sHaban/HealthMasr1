@{
    ViewData["Title"] = "Reset Password";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="auth-wrap">
    <div class="auth-card">
        <div style="text-align:center; margin-bottom:20px;">
            <span class="logo-part1">Health</span><span class="logo-part2">MSR</span>
        </div>
        <h2 class="auth-title">Reset Password</h2>

        @if (ViewBag.Error != null)
        {
            <div class="error-msg">@ViewBag.Error</div>
        }

        <form method="post">
            <input type="hidden" name="token" value="@ViewBag.Token" />
            <input type="hidden" name="email" value="@ViewBag.Email" />
            <input type="hidden" name="role" value="@ViewBag.Role" />

            <div class="input-group" style="margin-bottom:16px;">
                <label>New Password</label>
                <input type="password" name="newPassword" placeholder="Min 6 characters" minlength="6" required />
            </div>
            <div class="input-group" style="margin-bottom:16px;">
                <label>Confirm Password</label>
                <input type="password" name="confirmPassword" placeholder="Confirm password" required />
            </div>
            <button type="submit" class="btn-primary">Reset Password</button>
        </form>
    </div>
</div>