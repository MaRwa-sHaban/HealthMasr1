<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HealthMSR</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Playball&family=Cormorant+Garamond:wght@500;600&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
            .reveal {
                opacity: 0;
                transform: translateY(40px);
                transition: all 0.8s ease;
            }

                .reveal.active {
                    opacity: 1;
                    transform: translateY(0);
                }
    </style>
</head>
<body>
    @RenderBody()
    <button id="darkToggle" onclick="toggleDark()"
            style="position:fixed; bottom:24px; right:24px; width:48px; height:48px;
        border-radius:50%; border:2px solid var(--teal);
        background:transparent; cursor:pointer; font-size:1.3rem;
        z-index:9999; box-shadow:0 4px 20px rgba(14,165,233,0.15);
        transition:0.3s; display:flex; align-items:center; justify-content:center;">
        🌙
    </button>
    <!-- كل الـ Scripts هنا في الآخر -->
    <body>
        <!-- Mobile Menu Button -->
        <button class="mobile-menu-btn" id="mobileMenuBtn"
                onclick="toggleSidebar()"
                style="display:none; position:fixed; top:12px; left:12px; z-index:9999;
            width:44px; height:44px; border-radius:12px; border:none;
            background:var(--teal-dark); color:white; font-size:1.3rem;
            cursor:pointer; align-items:center; justify-content:center;">
            ☰
        </button>

        @RenderBody()
        <script src="~/js/healthmsr.js"></script>
        @await RenderSectionAsync("Scripts", required: false)
    </body>
    <script>
            document.querySelectorAll("section, .card").forEach(e => {
                e.classList.add("reveal");
            });

            const reveals = document.querySelectorAll(".reveal");

            window.addEventListener("scroll", reveal);

            function reveal() {
                reveals.forEach(element => {
                    if (element.getBoundingClientRect().top < window.innerHeight - 100) {
                        element.classList.add("active");
                    }
                });
            }

            reveal();
    </script>
</body>
</html>