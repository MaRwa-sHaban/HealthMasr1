@model HealthMSR.ViewModels.LabDashboardViewModel
@using HealthMSR.DAL.Enums
@{
    ViewData["Title"] = "Lab Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var lt = Model.LabTechnician;
}

<div class="dashboard-wrap">

    <aside class="sidebar">
        <div class="sidebar-logo">
            <span class="logo-part1">Health</span><span class="logo-part2">MSR</span>
        </div>
        <div class="sidebar-profile">
            <div class="profile-avatar">@lt.Name[0]</div>
            <div class="profile-name">@lt.Name</div>
            <div class="profile-role">Lab Specialist</div>
        </div>
        <nav class="sidebar-nav">
            <a href="@Url.Action("Dashboard", "Lab", new { section = "overview" })"
               class="nav-item @(Model.ActiveSection == "overview" ? "active" : "")">Overview</a>
            <a href="@Url.Action("Dashboard", "Lab", new { section = "pending" })"
                   class="nav-item @(Model.ActiveSection == "pending" ? "active" : "")">
                Pending Tests
                @if (Model.PendingLabs.Any())
                {
                    <span style="background:#ef4444; color:white; font-size:0.7rem; font-weight:700; padding:2px 7px; border-radius:20px; margin-left:auto;">
                        @Model.PendingLabs.Count
                    </span>
                }
            </a>
            <a href="@Url.Action("Dashboard", "Lab", new { section = "search" })"
               class="nav-item @(Model.ActiveSection == "search" ? "active" : "")">Search Patient</a>
            <a href="@Url.Action("Dashboard", "Lab", new { section = "profile" })"
               class="nav-item @(Model.ActiveSection == "profile" ? "active" : "")">My Profile</a>
        </nav>
        <a href="@Url.Action("Logout", "Auth")" class="logout-btn">Logout</a>
    </aside>

    <main class="main-content">
        <div class="topbar">
            <h2 class="page-title">
                @if (Model.ActiveSection == "overview")
                {
                    <text>Welcome, @lt.Name</text>
                }
                @if (Model.ActiveSection == "pending")
                {
                    <text>Pending Tests</text>
                }
                @if (Model.ActiveSection == "search")
                {
                    <text>Search Patient</text>
                }
                @if (Model.ActiveSection == "profile")
                {
                    <text>My Profile</text>
                }
            </h2>
        </div>

        <div class="page-content">

            @* OVERVIEW *@
            @if (Model.ActiveSection == "overview")
            {
                <div class="stats-grid" style="grid-template-columns:repeat(2,1fr);">
                    <div class="stat-card">
                        <div class="stat-icon orange">🧪</div>
                        <div class="stat-info">
                            <span class="stat-num">@Model.PendingLabs.Count</span>
                            <span class="stat-label">Pending Tests</span>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon green">✅</div>
                        <div class="stat-info">
                            <span class="stat-num">@Model.CompletedToday</span>
                            <span class="stat-label">Completed Today</span>
                        </div>
                    </div>
                </div>

                @if (Model.PendingLabs.Any())
                {
                    <div class="section-card">
                        <h3 class="section-heading">Tests Awaiting Results</h3>
                        @foreach (var item in Model.PendingLabs)
                        {
                            <div style="border:1px solid var(--border); border-radius:14px; padding:18px; margin-bottom:14px; border-left:4px solid var(--teal);">
                                <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:12px;">
                                    <div>
                                        <div style="font-family:'Cormorant Garamond',serif; font-size:1.1rem; font-weight:600; color:var(--dark);">@item.PatientName</div>
                                        <div style="font-size:0.78rem; color:var(--gray);">@item.PatientNationalId</div>
                                    </div>
                                    <div style="text-align:right;">
                                        <div style="font-weight:700; color:var(--teal-dark);">@item.LabReport.TestName</div>
                                    </div>
                                </div>
                                <form asp-action="UploadResult" asp-controller="Lab" method="post"
                                      style="display:flex; gap:10px; align-items:center;">
                                    <input type="hidden" name="reportId" value="@item.LabReport.ReportId" />
                                    <input type="hidden" name="patientNationalId" value="@item.PatientNationalId" />
                                    <input type="text" name="result" placeholder="Enter result..."
                                           style="flex:1; padding:11px 16px; border-radius:12px; border:2px solid var(--teal); outline:none; font-size:0.92rem;" required />
                                    <button type="submit"
                                            style="padding:11px 20px; border-radius:12px; border:none; background:linear-gradient(135deg,#059669,#10b981); color:white; font-weight:700; cursor:pointer; white-space:nowrap;">
                                        Upload Result
                                    </button>
                                </form>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="section-card">
                        <div class="empty-state">
                            <div class="empty-icon">✅</div>
                            <p>No pending tests</p>
                        </div>
                    </div>
                }
            }

            @* PENDING *@
            @if (Model.ActiveSection == "pending")
            {
                <div class="section-card">
                    <h3 class="section-heading">Pending Tests</h3>
                    @if (!Model.PendingLabs.Any())
                    {
                        <div class="empty-state">
                            <div class="empty-icon">✅</div>
                            <p>All tests completed</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var item in Model.PendingLabs)
                        {
                            <div style="border:1px solid var(--border); border-radius:14px; padding:18px; margin-bottom:14px; border-left:4px solid var(--teal);">
                                <div style="display:flex; justify-content:space-between; margin-bottom:12px;">
                                    <div>
                                        <div style="font-family:'Cormorant Garamond',serif; font-size:1.1rem; font-weight:600;">@item.PatientName</div>
                                        <div style="font-size:0.78rem; color:var(--gray);">@item.PatientNationalId</div>
                                    </div>
                                    <div style="font-weight:700; color:var(--teal-dark);">@item.LabReport.TestName</div>
                                </div>
                                <form asp-action="UploadResult" asp-controller="Lab" method="post"
                                      style="display:flex; gap:10px;">
                                    <input type="hidden" name="reportId" value="@item.LabReport.ReportId" />
                                    <input type="hidden" name="patientNationalId" value="@item.PatientNationalId" />
                                    <input type="text" name="result" placeholder="Enter result..."
                                           style="flex:1; padding:11px 16px; border-radius:12px; border:2px solid var(--teal); outline:none;" required />
                                    <button type="submit"
                                            style="padding:11px 20px; border-radius:12px; border:none; background:linear-gradient(135deg,#059669,#10b981); color:white; font-weight:700; cursor:pointer;">
                                        Upload
                                    </button>
                                </form>
                            </div>
                        }
                    }
                </div>
            }

            @* SEARCH *@
            @if (Model.ActiveSection == "search")
            {
                <div class="section-card">
                    <h3 class="section-heading">Search by National ID</h3>
                    <form method="get" asp-action="Dashboard" asp-controller="Lab"
                          style="display:flex; gap:12px;">
                        <input type="hidden" name="section" value="search" />
                        <input type="text" name="searchId" placeholder="Enter 14-digit National ID" maxlength="14"
                               style="flex:1; padding:14px 18px; border-radius:12px; border:2px solid var(--border); font-size:1rem; outline:none;" />
                        <button type="submit" class="btn-primary" style="width:auto; padding:14px 28px;">Search</button>
                    </form>
                    @if (!string.IsNullOrEmpty(Model.SearchError))
                    {
                        <div class="error-msg" style="margin-top:12px;">@Model.SearchError</div>
                    }
                </div>

                @if (Model.SearchedPatient != null)
                {
                    var pat = Model.SearchedPatient;
                    <div style="background:linear-gradient(135deg,#0f172a,#0369a1); border-radius:18px; padding:24px; display:flex; align-items:center; gap:20px; margin-bottom:20px;">
                        <div class="profile-avatar" style="width:72px; height:72px; font-size:2.2rem;">@pat.FirstName[0]</div>
                        <div>
                            <h2 style="font-family:'Cormorant Garamond',serif; font-size:1.8rem; color:white; margin-bottom:8px;">
                                @pat.FirstName @pat.LastName
                            </h2>
                            <span style="background:rgba(255,255,255,0.15); color:#e0f2fe; padding:4px 12px; border-radius:20px; font-size:0.82rem;">@pat.NationalId</span>
                        </div>
                    </div>

                    <div class="section-card">
                        <h3 class="section-heading">Lab Tests</h3>
                        @if (!Model.PatientLabReports.Any())
                        {
                            <div class="empty-state">
                                <div class="empty-icon">🧪</div>
                                <p>No lab tests yet</p>
                            </div>
                        }
                        else
                        {
                            @foreach (var lab in Model.PatientLabReports)
                            {
                                <div style="border:1px solid var(--border); border-radius:14px; padding:18px; margin-bottom:14px; border-left:4px solid @(lab.Status == LabStatus.Completed ? "#10b981" : "var(--teal)");">
                                    <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:10px;">
                                        <div>
                                            <div style="font-weight:700; color:var(--teal-dark);">@lab.TestName</div>
                                            <div style="font-size:0.85rem; color:var(--gray); margin-top:4px;">@lab.Results</div>
                                        </div>
                                        <span class="status-badge @(lab.Status == LabStatus.Completed ? "completed" : "pending")">
                                            @lab.Status
                                        </span>
                                    </div>
                                    @if (lab.Status == LabStatus.Pending)
                                    {
                                        <form asp-action="UploadResult" asp-controller="Lab" method="post"
                                              style="display:flex; gap:10px; margin-top:10px;">
                                            <input type="hidden" name="reportId" value="@lab.ReportId" />
                                            <input type="hidden" name="patientNationalId" value="@pat.NationalId" />
                                            <input type="text" name="result" placeholder="Enter result..."
                                                   style="flex:1; padding:11px 16px; border-radius:12px; border:2px solid var(--teal); outline:none;" required />
                                            <button type="submit"
                                                    style="padding:11px 20px; border-radius:12px; border:none; background:linear-gradient(135deg,#059669,#10b981); color:white; font-weight:700; cursor:pointer;">
                                                Upload
                                            </button>
                                        </form>
                                    }
                                </div>
                            }
                        }
                    </div>
                }
            }

            @* PROFILE *@
            @if (Model.ActiveSection == "profile")
            {
                <div class="section-card" style="text-align:center;">
                    <div class="profile-avatar" style="width:100px; height:100px; font-size:3rem; margin:0 auto 16px; box-shadow:0 8px 24px rgba(14,165,233,0.3);">
                        @lt.Name[0]
                    </div>
                    <h2 style="font-family:'Cormorant Garamond',serif; font-size:2rem; color:var(--dark); margin-bottom:12px;">@lt.Name</h2>
                    <span class="status-badge completed" style="background:#fef3c7; color:#92400e;">Lab Specialist</span>

                    <div style="display:grid; grid-template-columns:repeat(2,1fr); gap:16px; margin-top:28px; text-align:left;">
                        @foreach (var item in new[] {
                new { Label = "National ID",  Value = lt.NationalId ?? "—" },
                new { Label = "Speciality",   Value = lt.Speciality ?? "—" },
                new { Label = "Phone",        Value = lt.Phone ?? "—" },
                new { Label = "Email",        Value = lt.Email ?? "—" }
            })
                        {
                            <div style="background:var(--bg); border-radius:12px; padding:16px 20px; border:1px solid var(--border);">
                                <span style="display:block; font-size:0.75rem; color:var(--teal-dark); font-weight:700; text-transform:uppercase; letter-spacing:1px; margin-bottom:6px;">@item.Label</span>
                                <span style="font-family:'Cormorant Garamond',serif; font-size:1.3rem; font-weight:600; color:var(--dark);">@item.Value</span>
                            </div>
                        }
                    </div>
                </div>
            }

        </div>
    </main>
</div>