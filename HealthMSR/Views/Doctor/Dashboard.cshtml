@model HealthMSR.ViewModels.DoctorDashboardViewModel
@using HealthMSR.DAL.Enums
@inject HealthMSR.DAL.AppDbContext _db
@* @model HealthMSR.ViewModels.DoctorDashboardViewModel *@
@* @using HealthMSR.Enums *@
@using HealthMSR.DAL
@{
    ViewData["Title"] = "Doctor Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var d = Model.Doctor;
}

<div class="dashboard-wrap">

    <!-- SIDEBAR -->
    <aside class="sidebar">
        <div class="sidebar-logo">
            <span class="logo-part1">Health</span><span class="logo-part2">MSR</span>
        </div>

        <div class="sidebar-profile">
            <div class="profile-avatar">@d.FullName[0]</div>
            <div class="profile-name">Dr. @d.FullName</div>
            <div class="profile-role">@d.Specialty</div>
            <div class="profile-id">@d.LicenseNumber</div>
        </div>

        <nav class="sidebar-nav">
            <a href="@Url.Action("Dashboard", "Doctor", new { section = "overview" })"
               class="nav-item @(Model.ActiveSection == "overview" ? "active" : "")">Overview</a>
            <a href="@Url.Action("Dashboard", "Doctor", new { section = "search" })"
               class="nav-item @(Model.ActiveSection == "search" ? "active" : "")">Search Patient</a>
            <a href="@Url.Action("Dashboard", "Doctor", new { section = "profile" })"
               class="nav-item @(Model.ActiveSection == "profile" ? "active" : "")">My Profile</a>
        </nav>

        <a href="@Url.Action("Logout", "Auth")" class="logout-btn">Logout</a>
    </aside>

    <!-- MAIN -->
    <main class="main-content">
        <div class="topbar">
            <h2 class="page-title">
                @if (Model.ActiveSection == "overview") { <text>Welcome, Dr. @d.FullName</text> }
                @if (Model.ActiveSection == "search") { <text>Search Patient</text> }
                @if (Model.ActiveSection == "profile") { <text>My Profile</text> }
            </h2>
        </div>

        <div class="page-content">

            @* OVERVIEW *@
            @if (Model.ActiveSection == "overview")
            {
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-icon blue">👥</div>
                        <div class="stat-info">
                            <span class="stat-num">@Model.TodayPatients</span>
                            <span class="stat-label">Patients Today</span>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon green">💊</div>
                        <div class="stat-info">
                            <span class="stat-num">@Model.TodayPrescriptions</span>
                            <span class="stat-label">Prescriptions</span>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon purple">🧪</div>
                        <div class="stat-info">
                            <span class="stat-num">@Model.TodayLabRequests</span>
                            <span class="stat-label">Lab Requests</span>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon orange">🩻</div>
                        <div class="stat-info">
                            <span class="stat-num">@Model.TodayRadRequests</span>
                            <span class="stat-label">Rad Requests</span>
                        </div>
                    </div>
                </div>

                <div class="section-card">
                    <div class="empty-state">
                        <div class="empty-icon">🔍</div>
                        <p>Search for a patient to start a session</p>
                        <a href="@Url.Action("Dashboard", "Doctor", new { section = "search" })"
                           class="btn-primary" style="display:inline-block; width:auto; padding:12px 28px; margin-top:16px; text-decoration:none;">
                            Search Patient
                        </a>
                    </div>
                </div>
            }

            @if (Model.ActiveSection == "search")
            {
                <div class="section-card">
                    <h3 class="section-heading">Search by National ID</h3>
                    <form method="get" asp-action="Dashboard" asp-controller="Doctor"
                          style="display:flex; gap:12px;" id="searchForm">
                        <input type="hidden" name="section" value="search" />
                        <div style="flex:1; position:relative;">
                            <input type="text" name="searchId" id="searchInput"
                                   placeholder="Enter 14-digit National ID"
                                   maxlength="14" oninput="validateNID(this)"
                                   style="width:100%; padding:14px 18px; border-radius:12px; border:2px solid var(--border); font-size:1rem; outline:none; background:#f8fafc;" />
                            <div id="nidError"
                                 style="display:none; color:#ef4444; font-size:0.82rem; font-weight:500; margin-top:6px; padding:8px 12px; background:#fff5f5; border-radius:8px;">
                                National ID must be exactly 14 digits
                            </div>
                        </div>
                        <button type="submit" class="btn-primary"
                                style="width:auto; padding:14px 28px;"
                                onclick="return checkNID()">
                            Search
                        </button>
                    </form>

                    @if (!string.IsNullOrEmpty(Model.SearchError))
                    {
                        <div class="error-msg" style="margin-top:12px;">@Model.SearchError</div>
                    }
                </div>

                @if (Model.SearchedPatient != null)
                {
                    var pat = Model.SearchedPatient;
                    var patAge = DateTime.Now.Year - pat.DateOfBirth.Year;

                    <!-- Patient Header -->
                    <div style="background:linear-gradient(135deg,#0f172a,#0369a1); border-radius:18px; padding:24px; display:flex; align-items:center; gap:20px; margin-bottom:24px; box-shadow:0 8px 32px rgba(14,165,233,0.2);">
                        <div class="profile-avatar" style="width:72px; height:72px; font-size:2.2rem; border:3px solid rgba(255,255,255,0.3); flex-shrink:0;">
                            @pat.FirstName[0]
                        </div>
                        <div style="flex:1;">
                            <a href="@Url.Action("PatientProfile", "Doctor", new { patientId = pat.PatientId })"
                                   style="font-family:'Cormorant Garamond',serif; font-size:1.8rem; color:white; font-weight:600; text-decoration:none; display:block; margin-bottom:8px;">
                                @pat.FirstName @pat.LastName ↗
                            </a>
                            <div style="display:flex; gap:10px; flex-wrap:wrap;">
                                <span style="background:rgba(255,255,255,0.15); color:#e0f2fe; padding:4px 12px; border-radius:20px; font-size:0.82rem;">@pat.NationalId</span>
                                <span style="background:rgba(255,255,255,0.15); color:#e0f2fe; padding:4px 12px; border-radius:20px; font-size:0.82rem;">@(pat.MedicalRecord?.BloodType ?? "—")</span>
                                <span style="background:rgba(255,255,255,0.15); color:#e0f2fe; padding:4px 12px; border-radius:20px; font-size:0.82rem;">@patAge yrs</span>
                            </div>
                        </div>
                    </div>

                    <!-- UNIFIED VISIT FORM -->
                    <div class="section-card">
                        <h3 class="section-heading">New Visit</h3>

                        @* آخر زيارة *@
                        @if (Model.PatientEncounters.Any())
                        {
                            var last = Model.PatientEncounters.First();
                            <div style="background:var(--teal-light); border-radius:12px; padding:14px 18px; margin-bottom:24px; border-left:4px solid var(--teal); display:flex; justify-content:space-between; align-items:center;">
                                <div>
                                    <span style="font-size:0.75rem; font-weight:700; color:var(--teal-dark); text-transform:uppercase; letter-spacing:1px;">Last Visit</span>
                                    <div style="font-family:'Cormorant Garamond',serif; font-size:1rem; color:var(--dark); margin-top:4px;">@last.Status</div>
                                </div>
                                <span style="font-size:0.78rem; color:var(--gray);">@last.StartTime.ToString("yyyy-MM-dd")</span>
                            </div>
                        }

                        <form asp-action="SaveVisit" asp-controller="Doctor" method="post">
                            <input type="hidden" name="PatientId" value="@pat.PatientId" />

                            <!-- SECTION 1: Diagnosis -->
                            <div style="margin-bottom:28px; padding-bottom:28px; border-bottom:2px dashed var(--border);">
                                <h4 style="font-family:'Cormorant Garamond',serif; font-size:1.3rem; color:var(--teal-dark); margin-bottom:16px; display:flex; align-items:center; gap:10px;">
                                    <span style="background:var(--teal); color:white; width:28px; height:28px; border-radius:50%; display:inline-flex; align-items:center; justify-content:center; font-size:0.85rem; font-family:'Plus Jakarta Sans',sans-serif;">1</span>
                                    Diagnosis <span style="color:#ef4444; font-size:0.9rem;">*</span>
                                </h4>
                                <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
                                    <div class="input-group" style="grid-column:span 2;">
                                        <label>Diagnosis</label>
                                        <input type="text" name="Diagnosis"
                                               placeholder="e.g. Hypertension, Diabetes Type 2..."
                                               style="padding:13px 16px; border-radius:12px; border:2px solid var(--border); width:100%; font-size:0.95rem; outline:none;"
                                               required />
                                    </div>
                                    <div class="input-group" style="grid-column:span 2;">
                                        <label>Notes (optional)</label>
                                        <textarea name="Notes" rows="2" placeholder="Additional clinical notes..."
                                                  style="padding:13px 16px; border-radius:12px; border:2px solid var(--border); width:100%; font-size:0.95rem; outline:none; resize:vertical; font-family:'Plus Jakarta Sans',sans-serif;"></textarea>
                                    </div>
                                </div>
                            </div>

                            <!-- SECTION 2: Vital Signs -->
                            <div style="margin-bottom:28px; padding-bottom:28px; border-bottom:2px dashed var(--border);">
                                <h4 style="font-family:'Cormorant Garamond',serif; font-size:1.3rem; color:var(--teal-dark); margin-bottom:16px; display:flex; align-items:center; gap:10px;">
                                    <span style="background:#6d28d9; color:white; width:28px; height:28px; border-radius:50%; display:inline-flex; align-items:center; justify-content:center; font-size:0.85rem; font-family:'Plus Jakarta Sans',sans-serif;">2</span>
                                    Vital Signs <span style="font-size:0.82rem; color:var(--gray); font-family:'Plus Jakarta Sans',sans-serif; font-weight:400;">(optional)</span>
                                </h4>
                                <div style="display:grid; grid-template-columns:repeat(4,1fr); gap:14px;">
                                    <div class="input-group">
                                        <label>🩺 Blood Pressure</label>
                                        <input type="text" name="BP" placeholder="120/80 mmHg"
                                               style="padding:12px 14px; border-radius:12px; border:2px solid var(--border); width:100%; font-size:0.9rem; outline:none;" />
                                    </div>
                                    <div class="input-group">
                                        <label>🩸 Blood Sugar</label>
                                        <input type="text" name="Sugar" placeholder="mg/dL"
                                               style="padding:12px 14px; border-radius:12px; border:2px solid var(--border); width:100%; font-size:0.9rem; outline:none;" />
                                    </div>
                                    <div class="input-group">
                                        <label>🌡️ Temperature</label>
                                        <input type="text" name="Temp" placeholder="°C"
                                               style="padding:12px 14px; border-radius:12px; border:2px solid var(--border); width:100%; font-size:0.9rem; outline:none;" />
                                    </div>
                                    <div class="input-group">
                                        <label>❤️ Pulse</label>
                                        <input type="text" name="Pulse" placeholder="bpm"
                                               style="padding:12px 14px; border-radius:12px; border:2px solid var(--border); width:100%; font-size:0.9rem; outline:none;" />
                                    </div>
                                </div>
                            </div>

                            <!-- SECTION 3: Prescription -->
                            <div style="margin-bottom:28px; padding-bottom:28px; border-bottom:2px dashed var(--border);">
                                <h4 style="font-family:'Cormorant Garamond',serif; font-size:1.3rem; color:var(--teal-dark); margin-bottom:16px; display:flex; align-items:center; gap:10px;">
                                    <span style="background:#059669; color:white; width:28px; height:28px; border-radius:50%; display:inline-flex; align-items:center; justify-content:center; font-size:0.85rem; font-family:'Plus Jakarta Sans',sans-serif;">3</span>
                                    Prescription <span style="font-size:0.82rem; color:var(--gray); font-family:'Plus Jakarta Sans',sans-serif; font-weight:400;">(optional)</span>
                                </h4>

                                <div id="medList" style="display:flex; flex-direction:column; gap:12px;">
                                    <div class="med-row" style="display:grid; grid-template-columns:2fr 1fr 1.5fr 1fr auto; gap:10px; align-items:end;">
                                        <div class="input-group">
                                            <label>Medication</label>
                                            <input type="text" name="medName" placeholder="e.g. Amoxicillin"
                                                   style="padding:12px 14px; border-radius:12px; border:2px solid var(--border); width:100%; font-size:0.9rem; outline:none;" />
                                        </div>
                                        <div class="input-group">
                                            <label>Dosage</label>
                                            <input type="text" name="medDosage" placeholder="500mg"
                                                   style="padding:12px 14px; border-radius:12px; border:2px solid var(--border); width:100%; font-size:0.9rem; outline:none;" />
                                        </div>
                                        <div class="input-group">
                                            <label>Frequency</label>
                                            <select name="medFreq"
                                                    style="padding:12px 14px; border-radius:12px; border:2px solid var(--border); width:100%; font-size:0.9rem; outline:none; background:#f8fafc;">
                                                <option>Once daily</option>
                                                <option>Twice daily</option>
                                                <option>3 times daily</option>
                                                <option>Every 8 hours</option>
                                                <option>As needed</option>
                                            </select>
                                        </div>
                                        <div class="input-group">
                                            <label>Duration</label>
                                            <input type="text" name="medDuration" placeholder="7 days"
                                                   style="padding:12px 14px; border-radius:12px; border:2px solid var(--border); width:100%; font-size:0.9rem; outline:none;" />
                                        </div>
                                        <button type="button" onclick="removeMedRow(this)"
                                                style="padding:12px; border-radius:10px; border:none; background:#fee2e2; color:#ef4444; cursor:pointer; font-weight:700; display:none;">
                                            ✕
                                        </button>
                                    </div>
                                </div>

                                <button type="button" onclick="addMedRow2()"
                                        style="width:100%; margin-top:10px; padding:10px; border-radius:12px; border:2px dashed var(--teal); background:transparent; color:var(--teal-dark); font-weight:600; cursor:pointer; font-size:0.92rem; transition:0.3s;">
                                    + Add Medication
                                </button>

                                <div class="input-group" style="margin-top:14px;">
                                    <label>Prescription Notes</label>
                                    <input type="text" name="PrescriptionNotes" placeholder="e.g. Take after meals"
                                           style="padding:12px 14px; border-radius:12px; border:2px solid var(--border); width:100%; font-size:0.9rem; outline:none;" />
                                </div>
                            </div>

                            <!-- SECTION 4: Lab Tests -->
                            <div style="margin-bottom:28px; padding-bottom:28px; border-bottom:2px dashed var(--border);">
                                <h4 style="font-family:'Cormorant Garamond',serif; font-size:1.3rem; color:var(--teal-dark); margin-bottom:16px; display:flex; align-items:center; gap:10px;">
                                    <span style="background:#d97706; color:white; width:28px; height:28px; border-radius:50%; display:inline-flex; align-items:center; justify-content:center; font-size:0.85rem; font-family:'Plus Jakarta Sans',sans-serif;">4</span>
                                    Lab Tests <span style="font-size:0.82rem; color:var(--gray); font-family:'Plus Jakarta Sans',sans-serif; font-weight:400;">(optional)</span>
                                </h4>

                                <div id="labList" style="display:flex; flex-direction:column; gap:10px;">
                                    <div class="lab-row" style="display:flex; gap:10px; align-items:center;">
                                        <input type="text" name="labTest" placeholder="e.g. CBC, Blood Sugar, Liver Function..."
                                               style="flex:1; padding:12px 14px; border-radius:12px; border:2px solid var(--border); font-size:0.9rem; outline:none;" />
                                        <button type="button" onclick="removeRow(this)"
                                                style="padding:12px 14px; border-radius:10px; border:none; background:#fee2e2; color:#ef4444; cursor:pointer; font-weight:700; display:none;">
                                            ✕
                                        </button>
                                    </div>
                                </div>

                                <button type="button" onclick="addLabRow()"
                                        style="width:100%; margin-top:10px; padding:10px; border-radius:12px; border:2px dashed #d97706; background:transparent; color:#92400e; font-weight:600; cursor:pointer; font-size:0.92rem;">
                                    + Add Lab Test
                                </button>
                            </div>

                            <!-- SECTION 5: Radiology -->
                            <div style="margin-bottom:32px;">
                                <h4 style="font-family:'Cormorant Garamond',serif; font-size:1.3rem; color:var(--teal-dark); margin-bottom:16px; display:flex; align-items:center; gap:10px;">
                                    <span style="background:#be185d; color:white; width:28px; height:28px; border-radius:50%; display:inline-flex; align-items:center; justify-content:center; font-size:0.85rem; font-family:'Plus Jakarta Sans',sans-serif;">5</span>
                                    Radiology Scans <span style="font-size:0.82rem; color:var(--gray); font-family:'Plus Jakarta Sans',sans-serif; font-weight:400;">(optional)</span>
                                </h4>

                                <div id="radList" style="display:flex; flex-direction:column; gap:10px;">
                                    <div class="rad-row" style="display:flex; gap:10px; align-items:center;">
                                        <input type="text" name="radScan" placeholder="e.g. Chest X-Ray, MRI Brain, CT Abdomen..."
                                               style="flex:1; padding:12px 14px; border-radius:12px; border:2px solid var(--border); font-size:0.9rem; outline:none;" />
                                        <button type="button" onclick="removeRow(this)"
                                                style="padding:12px 14px; border-radius:10px; border:none; background:#fee2e2; color:#ef4444; cursor:pointer; font-weight:700; display:none;">
                                            ✕
                                        </button>
                                    </div>
                                </div>

                                <button type="button" onclick="addRadRow()"
                                        style="width:100%; margin-top:10px; padding:10px; border-radius:12px; border:2px dashed #be185d; background:transparent; color:#be185d; font-weight:600; cursor:pointer; font-size:0.92rem;">
                                    + Add Radiology Scan
                                </button>
                            </div>

                            <!-- SAVE BUTTON -->
                            <button type="submit"
                                    style="width:100%; padding:16px; border-radius:14px; border:none; background:linear-gradient(135deg,#0369a1,#0ea5e9); color:white; font-size:1.1rem; font-weight:700; cursor:pointer; font-family:'Plus Jakarta Sans',sans-serif; transition:0.3s; letter-spacing:0.5px; box-shadow:0 8px 24px rgba(14,165,233,0.3);">
                                💾 Save Visit
                            </button>
                        </form>
                    </div>

                    <!-- Previous Visits -->
                    @if (Model.PatientEncounters.Any())
                    {
                        <div class="section-card">
                            <h3 class="section-heading">Previous Visits</h3>
                            <div class="timeline">
                                @foreach (var enc in Model.PatientEncounters)
                                {
                                    var rxList = Model.PatientPrescriptions.Where(p => p.EncounterId == enc.EncounterId).ToList();
                                    var labList = Model.PatientLabReports.Where(l => l.EncounterId == enc.EncounterId).ToList();
                                    var radList = Model.PatientRadReports.Where(r => r.EncounterId == enc.EncounterId).ToList();

                                    <div class="timeline-item">
                                        <div class="timeline-dot"></div>
                                        <div class="timeline-body">
                                            <div class="timeline-date">@enc.StartTime.ToString("yyyy-MM-dd HH:mm")</div>
                                            <div class="timeline-title">@enc.Status</div>

                                            @if (rxList.Any())
                                            {
                                                <div style="margin-top:8px;">
                                                    <span style="font-size:0.75rem; font-weight:700; color:#059669; text-transform:uppercase;">💊 Prescriptions</span>
                                                    @foreach (var rx in rxList)
                                                    {
                                                        <div style="display:flex; flex-wrap:wrap; gap:6px; margin-top:4px;">
                                                            @foreach (var item in rx.Items)
                                                            {
                                                                <span style="background:#d1fae5; color:#065f46; padding:3px 10px; border-radius:20px; font-size:0.78rem;">
                                                                    @item.Medication?.DrugName @item.Dosage
                                                                </span>
                                                            }
                                                        </div>
                                                    }
                                                </div>
                                            }

                                            @if (labList.Any())
                                            {
                                                <div style="margin-top:8px;">
                                                    <span style="font-size:0.75rem; font-weight:700; color:#d97706; text-transform:uppercase;">🧪 Lab Tests</span>
                                                    <div style="display:flex; flex-wrap:wrap; gap:6px; margin-top:4px;">
                                                        @foreach (var lab in labList)
                                                        {
                                                            <span style="background:#fef3c7; color:#92400e; padding:3px 10px; border-radius:20px; font-size:0.78rem;">
                                                                @lab.TestName
                                                                <span class="status-badge @(lab.Status == LabStatus.Completed ? "completed" : "pending")" style="margin-left:4px; padding:1px 6px; font-size:0.7rem;">
                                                                    @lab.Status
                                                                </span>
                                                            </span>
                                                        }
                                                    </div>
                                                </div>
                                            }

                                            @if (radList.Any())
                                            {
                                                <div style="margin-top:8px;">
                                                    <span style="font-size:0.75rem; font-weight:700; color:#be185d; text-transform:uppercase;">🩻 Radiology</span>
                                                    <div style="display:flex; flex-wrap:wrap; gap:6px; margin-top:4px;">
                                                        @foreach (var rad in radList)
                                                        {
                                                            <span style="background:#fce7f3; color:#be185d; padding:3px 10px; border-radius:20px; font-size:0.78rem;">
                                                                @rad.ScanType
                                                                <span class="status-badge @(rad.Status == "Ready" ? "completed" : "pending")" style="margin-left:4px; padding:1px 6px; font-size:0.7rem;">
                                                                    @rad.Status
                                                                </span>
                                                            </span>
                                                        }
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
            }
            @* PROFILE *@
            @if (Model.ActiveSection == "profile")
            {
                var doctor = Model.Doctor;
                var age = doctor.NationalId?.Length >= 3
                    ? DateTime.Now.Year - (doctor.NationalId[0] == '2' ? 1900 : 2000)
                      - int.Parse(doctor.NationalId.Substring(1, 2)) : 0;

                <div class="section-card" style="text-align:center;">
                    <div style="width:100px; height:100px; border-radius:50%; background:linear-gradient(135deg,#0ea5e9,#0369a1); color:white; font-family:'Cormorant Garamond',serif; font-size:3rem; font-weight:600; display:flex; align-items:center; justify-content:center; margin:0 auto 16px; box-shadow:0 8px 24px rgba(14,165,233,0.3);">
                        @doctor.FullName[0]
                    </div>
                    <h2 style="font-family:'Cormorant Garamond',serif; font-size:2rem; color:var(--dark); margin-bottom:8px;">Dr. @doctor.FullName</h2>
                    <span style="background:var(--teal-light); color:var(--teal-dark); padding:6px 18px; border-radius:20px; font-size:0.9rem; font-weight:700; display:inline-block; margin-bottom:24px;">
                        @doctor.Specialty
                    </span>

                    <div style="display:grid; grid-template-columns:repeat(2,1fr); gap:16px; text-align:left;">
                        @foreach (var item in new[] {
                new { Label = "Full Name",       Value = "Dr. " + doctor.FullName },
                new { Label = "Specialty",        Value = doctor.Specialty ?? "—" },
                new { Label = "National ID",      Value = doctor.NationalId ?? "—" },
                new { Label = "License Number",   Value = doctor.LicenseNumber ?? "—" },
                new { Label = "Organization",     Value = doctor.Organization?.Name ?? "—" },
                new { Label = "Age",              Value = age + " years" }
            })
                        {
                            <div style="background:var(--bg); border-radius:12px; padding:16px 20px; border:1px solid var(--border);">
                                <span style="display:block; font-size:0.75rem; color:var(--teal-dark); font-weight:700; text-transform:uppercase; letter-spacing:1px; margin-bottom:6px;">@item.Label</span>
                                <span style="font-family:'Cormorant Garamond',serif; font-size:1.3rem; font-weight:600; color:var(--dark);">@item.Value</span>
                            </div>
                        }
                    </div>
                </div>
            }

        </div>
    </main>
</div>

@section Scripts {
    <script>
        function showTab(tabName) {
            document.querySelectorAll('.tab-content').forEach(el => el.style.display = 'none');
            document.querySelectorAll('.tab-btn').forEach(el => {
                el.style.background = 'var(--white)';
                el.style.color = 'var(--gray)';
                el.style.borderColor = 'var(--border)';
            });
            var content = document.getElementById('content-' + tabName);
            if (content) content.style.display = 'block';
            var btn = document.getElementById('tab-' + tabName);
            if (btn) {
                btn.style.background = 'var(--teal)';
                btn.style.color = 'white';
                btn.style.borderColor = 'var(--teal)';
            }
        }

        function addMedRow() {
            var list = document.getElementById('med-list');
            var row = list.querySelector('.med-row').cloneNode(true);
            row.querySelectorAll('input').forEach(i => i.value = '');
            list.appendChild(row);
        }

        function validateNID(input) {
            input.value = input.value.replace(/\D/g, '');
            var error = document.getElementById('nidError');
            if (input.value.length > 0 && input.value.length < 14) {
                error.style.display = 'block';
                error.textContent = '⚠️ National ID must be exactly 14 digits (' + input.value.length + '/14)';
            } else {
                error.style.display = 'none';
            }
        }

        function checkNID() {
            var input = document.getElementById('searchInput');
            var error = document.getElementById('nidError');
            if (!input) return true;
            if (input.value.length !== 14) {
                error.style.display = 'block';
                error.textContent = '⚠️ Please enter a complete 14-digit National ID';
                input.focus();
                return false;
            }
            return true;
        }

        document.addEventListener('DOMContentLoaded', function() {
            showTab('diagnosis');
        });
                function checkCustomFreq(select) {
            var customInput = select.nextElementSibling;
            if (select.value === 'custom') {
                customInput.style.display = 'block';
                customInput.name = select.name;
                select.name = '';
            } else {
                customInput.style.display = 'none';
                select.name = customInput.name || select.name;
                customInput.name = '';
            }
        }
    </script>

}