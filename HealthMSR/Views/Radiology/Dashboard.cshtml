@model HealthMSR.ViewModels.RadiologyDashboardViewModel
@{
    ViewData["Title"] = "Radiology Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var r = Model.Radiologist;
}

<div class="dashboard-wrap">

    <aside class="sidebar">
        <div class="sidebar-logo">
            <span class="logo-part1">Health</span><span class="logo-part2">MSR</span>
        </div>
        <div class="sidebar-profile">
            <div class="profile-avatar">@r.FullName[0]</div>
            <div class="profile-name">@r.FullName</div>
            <div class="profile-role">Radiologist</div>
            <div class="profile-id">@r.NationalId</div>
        </div>
        <nav class="sidebar-nav">
            <a href="@Url.Action("Dashboard", "Radiology", new { section = "overview" })"
               class="nav-item @(Model.ActiveSection == "overview" ? "active" : "")">Overview</a>
            <a href="@Url.Action("Dashboard", "Radiology", new { section = "pending" })"
                   class="nav-item @(Model.ActiveSection == "pending" ? "active" : "")">
                Pending Scans
                @if (Model.PendingScans.Any())
                {
                    <span style="background:#ef4444;color:white;font-size:0.7rem;font-weight:700;padding:2px 7px;border-radius:20px;margin-left:auto;">
                        @Model.PendingScans.Count
                    </span>
                }
            </a>
            <a href="@Url.Action("Dashboard", "Radiology", new { section = "search" })"
               class="nav-item @(Model.ActiveSection == "search" ? "active" : "")">Search Patient</a>
            <a href="@Url.Action("Dashboard", "Radiology", new { section = "profile" })"
               class="nav-item @(Model.ActiveSection == "profile" ? "active" : "")">My Profile</a>
        </nav>
        <a href="@Url.Action("Logout", "Auth")" class="logout-btn">Logout</a>
    </aside>

    <main class="main-content">
        <div class="topbar">
            <h2 class="page-title">
                @if (Model.ActiveSection == "overview")
                {
                    <text>Welcome, @r.FullName</text>
                }
                @if (Model.ActiveSection == "pending")
                {
                    <text>Pending Scans</text>
                }
                @if (Model.ActiveSection == "search")
                {
                    <text>Search Patient</text>
                }
                @if (Model.ActiveSection == "profile")
                {
                    <text>My Profile</text>
                }
            </h2>
        </div>

        <div class="page-content">

            @* OVERVIEW *@
            @if (Model.ActiveSection == "overview")
            {
                <div class="stats-grid" style="grid-template-columns:repeat(2,1fr);">
                    <div class="stat-card">
                        <div class="stat-icon orange">🩻</div>
                        <div class="stat-info">
                            <span class="stat-num">@Model.PendingScans.Count</span>
                            <span class="stat-label">Pending Scans</span>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon green">✅</div>
                        <div class="stat-info">
                            <span class="stat-num">@Model.CompletedToday</span>
                            <span class="stat-label">Completed Today</span>
                        </div>
                    </div>
                </div>

                @if (Model.PendingScans.Any())
                {
                    <div class="section-card">
                        <h3 class="section-heading">Scans Awaiting Results</h3>
                        @foreach (var item in Model.PendingScans)
                        {
                            <div style="border:1px solid var(--border);border-radius:14px;padding:18px;margin-bottom:14px;border-left:4px solid var(--teal);">
                                <div style="display:flex;justify-content:space-between;margin-bottom:12px;">
                                    <div>
                                        <div style="font-family:'Cormorant Garamond',serif;font-size:1.1rem;font-weight:600;">@item.PatientName</div>
                                        <div style="font-size:0.78rem;color:var(--gray);">@item.PatientNationalId</div>
                                    </div>
                                    <div style="text-align:right;">
                                        <div style="font-weight:700;color:var(--teal-dark);">@item.RadReport.ScanType</div>
                                        <div style="font-size:0.78rem;color:var(--gray);">@item.RadReport.RequestedDate.ToString("yyyy-MM-dd")</div>
                                    </div>
                                </div>
                                <form asp-action="UploadResult" asp-controller="Radiology" method="post"
                                      enctype="multipart/form-data">
                                    <input type="hidden" name="reportId" value="@item.RadReport.Id" />
                                    <input type="hidden" name="patientNationalId" value="@item.PatientNationalId" />

                                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:10px;">
                                        <div class="input-group">
                                            <label>Result Summary</label>
                                            <input type="text" name="result" placeholder="e.g. Clear, Normal..."
                                                   style="padding:11px 16px; border-radius:12px; border:2px solid var(--teal); outline:none;" required />
                                        </div>
                                        <div class="input-group">
                                            <label>Notes</label>
                                            <input type="text" name="notes" placeholder="Additional notes..."
                                                   style="padding:11px 16px; border-radius:12px; border:2px solid var(--border); outline:none;" />
                                        </div>
                                    </div>

                                    <label style="display:flex; align-items:center; gap:10px; padding:12px 16px; border-radius:12px; border:2px dashed var(--teal); background:var(--teal-light); cursor:pointer; margin-bottom:10px;">
                                        <span style="font-size:1.2rem;">📎</span>
                                        <span id="fileLabel_@item.RadReport.Id" style="font-size:0.88rem; color:var(--teal-dark); font-weight:600;">
                                            Upload Scan File (PDF or Image)
                                        </span>
                                        <input type="file" name="scanFile" accept=".pdf,image/jpeg,image/png"
                                               style="display:none;"
                                               onchange="document.getElementById('fileLabel_@item.RadReport.Id').textContent = this.files[0]?.name || 'Upload Scan File'" />
                                    </label>

                                    <button type="submit"
                                            style="padding:11px 20px; border-radius:12px; border:none; background:linear-gradient(135deg,#059669,#10b981); color:white; font-weight:700; cursor:pointer;">
                                        Upload Result
                                    </button>
                                </form>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="section-card">
                        <div class="empty-state">
                            <div class="empty-icon">✅</div>
                            <p>No pending scans</p>
                        </div>
                    </div>
                }
            }

            @* PENDING *@
            @if (Model.ActiveSection == "pending")
            {
                <div class="section-card">
                    <h3 class="section-heading">Pending Scans</h3>
                    @if (!Model.PendingScans.Any())
                    {
                        <div class="empty-state">
                            <div class="empty-icon">✅</div>
                            <p>All scans completed</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var item in Model.PendingScans)
                        {
                            <div style="border:1px solid var(--border);border-radius:14px;padding:18px;margin-bottom:14px;border-left:4px solid var(--teal);">
                                <div style="display:flex;justify-content:space-between;margin-bottom:12px;">
                                    <div>
                                        <div style="font-family:'Cormorant Garamond',serif;font-size:1.1rem;font-weight:600;">@item.PatientName</div>
                                        <div style="font-size:0.78rem;color:var(--gray);">@item.PatientNationalId</div>
                                    </div>
                                    <div style="text-align:right;">
                                        <div style="font-weight:700;color:var(--teal-dark);">@item.RadReport.ScanType</div>
                                        <div style="font-size:0.78rem;color:var(--gray);">@item.RadReport.RequestedDate.ToString("yyyy-MM-dd")</div>
                                    </div>
                                </div>
                                <form asp-action="UploadResult" asp-controller="Radiology" method="post"
                                      enctype="multipart/form-data">
                                    <input type="hidden" name="reportId" value="@item.RadReport.Id" />
                                    <input type="hidden" name="patientNationalId" value="@item.PatientNationalId" />

                                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:10px;">
                                        <input type="text" name="result" placeholder="Result summary..."
                                               style="padding:11px 16px; border-radius:12px; border:2px solid var(--teal); outline:none;" required />
                                        <input type="text" name="notes" placeholder="Notes..."
                                               style="padding:11px 16px; border-radius:12px; border:2px solid var(--border); outline:none;" />
                                    </div>

                                    <!-- File Upload -->
                                    <label style="display:flex; align-items:center; gap:10px; padding:12px 16px; border-radius:12px; border:2px dashed var(--teal); background:var(--teal-light); cursor:pointer; margin-bottom:10px;">
                                        <span style="font-size:1.2rem;">📎</span>
                                        <span id="fileLabel_@item.RadReport.Id" style="font-size:0.88rem; color:var(--teal-dark); font-weight:600;">
                                            Upload Scan File (PDF or Image)
                                        </span>
                                        <input type="file" name="scanFile" accept=".pdf,image/jpeg,image/png"
                                               style="display:none;"
                                               onchange="document.getElementById('fileLabel_@item.RadReport.Id').textContent = this.files[0]?.name || 'Upload Scan File'" />
                                    </label>

                                    <button type="submit"
                                            style="padding:11px 20px; border-radius:12px; border:none; background:linear-gradient(135deg,#059669,#10b981); color:white; font-weight:700; cursor:pointer;">
                                        Upload Result
                                    </button>
                                </form>
                            </div>
                        }
                    }
                </div>
            }

            @* SEARCH *@
            @if (Model.ActiveSection == "search")
            {
                <div class="section-card">
                    <h3 class="section-heading">Search by National ID</h3>
                    <form method="get" asp-action="Dashboard" asp-controller="Radiology"
                          style="display:flex;gap:12px;">
                        <input type="hidden" name="section" value="search" />
                        <input type="text" name="searchId" placeholder="Enter 14-digit National ID"
                               maxlength="14"
                               style="flex:1;padding:14px 18px;border-radius:12px;border:2px solid var(--border);font-size:1rem;outline:none;" />
                        <button type="submit" class="btn-primary" style="width:auto;padding:14px 28px;">Search</button>
                    </form>
                    @if (!string.IsNullOrEmpty(Model.SearchError))
                    {
                        <div class="error-msg" style="margin-top:12px;">@Model.SearchError</div>
                    }
                </div>

                @if (Model.SearchedPatient != null)
                {
                    var pat = Model.SearchedPatient;
                    <div style="background:linear-gradient(135deg,#0f172a,#0369a1);border-radius:18px;padding:24px;display:flex;align-items:center;gap:20px;margin-bottom:20px;box-shadow:0 8px 32px rgba(14,165,233,0.2);">
                        <div class="profile-avatar" style="width:72px;height:72px;font-size:2.2rem;border:3px solid rgba(255,255,255,0.3);">@pat.FirstName[0]</div>
                        <div>
                            <h2 style="font-family:'Cormorant Garamond',serif;font-size:1.8rem;color:white;margin-bottom:8px;">@pat.FirstName @pat.LastName</h2>
                            <span style="background:rgba(255,255,255,0.15);color:#e0f2fe;padding:4px 12px;border-radius:20px;font-size:0.82rem;">@pat.NationalId</span>
                        </div>
                    </div>

                    <div class="section-card">
                        <h3 class="section-heading">Radiology Reports</h3>
                        @if (!Model.PatientRadReports.Any())
                        {
                            <div class="empty-state">
                                <div class="empty-icon">🩻</div>
                                <p>No radiology reports yet</p>
                            </div>
                        }
                        else
                        {
                            @foreach (var rad in Model.PatientRadReports)
                            {
                                <div style="border:1px solid var(--border);border-radius:14px;padding:18px;margin-bottom:14px;border-left:4px solid @(rad.Status == "Ready" ? "#10b981" : "var(--teal)");">
                                    <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px;">
                                        <div>
                                            <div style="font-weight:700;color:var(--teal-dark);">🩻 @rad.ScanType</div>
                                            @if (!string.IsNullOrEmpty(rad.Result))
                                            {
                                                <div style="font-size:0.85rem;color:var(--gray);margin-top:4px;">@rad.Result</div>
                                            }
                                            @if (!string.IsNullOrEmpty(rad.Notes))
                                            {
                                                <div style="font-size:0.82rem;color:var(--gray);">Notes: @rad.Notes</div>
                                            }
                                        </div>
                                        <div style="text-align:right;">
                                            <div style="font-size:0.78rem;color:var(--gray);">@rad.RequestedDate.ToString("yyyy-MM-dd")</div>
                                            <span class="status-badge @(rad.Status == "Ready" ? "completed" : "pending")" style="display:inline-block;margin-top:6px;">
                                                @rad.Status
                                            </span>
                                        </div>
                                    </div>
                                    @if (rad.Status == "Pending")
                                    {
                                        <form asp-action="UploadResult" asp-controller="Radiology" method="post"
                                              style="display:flex;gap:10px;margin-top:10px;">
                                            <input type="hidden" name="reportId" value="@rad.Id" />
                                            <input type="hidden" name="patientNationalId" value="@pat.NationalId" />
                                            <input type="text" name="result" placeholder="Enter result..."
                                                   style="flex:1;padding:11px 16px;border-radius:12px;border:2px solid var(--teal);outline:none;" required />
                                            <input type="text" name="notes" placeholder="Notes..."
                                                   style="flex:1;padding:11px 16px;border-radius:12px;border:2px solid var(--border);outline:none;" />
                                            <button type="submit"
                                                    style="padding:11px 20px;border-radius:12px;border:none;background:linear-gradient(135deg,#059669,#10b981);color:white;font-weight:700;cursor:pointer;white-space:nowrap;">
                                                Upload
                                            </button>
                                        </form>
                                    }
                                </div>
                            }
                        }
                    </div>
                }
            }

            @* PROFILE *@
            @if (Model.ActiveSection == "profile")
            {
                <div class="section-card" style="text-align:center;">
                    <div class="profile-avatar" style="width:100px;height:100px;font-size:3rem;margin:0 auto 16px;box-shadow:0 8px 24px rgba(14,165,233,0.3);">@r.FullName[0]</div>
                    <h2 style="font-family:'Cormorant Garamond',serif;font-size:2rem;color:var(--dark);margin-bottom:12px;">@r.FullName</h2>
                    <span class="status-badge completed">Radiologist</span>
                    <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:16px;margin-top:28px;text-align:left;">
                        <div style="background:var(--bg);border-radius:12px;padding:16px 20px;border:1px solid var(--border);">
                            <span style="display:block;font-size:0.75rem;color:var(--teal-dark);font-weight:700;text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;">National ID</span>
                            <span style="font-family:'Cormorant Garamond',serif;font-size:1.3rem;font-weight:600;">@r.NationalId</span>
                        </div>
                        <div style="background:var(--bg);border-radius:12px;padding:16px 20px;border:1px solid var(--border);">
                            <span style="display:block;font-size:0.75rem;color:var(--teal-dark);font-weight:700;text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;">Phone</span>
                            <span style="font-family:'Cormorant Garamond',serif;font-size:1.3rem;font-weight:600;">@(r.Phone ?? "—")</span>
                        </div>
                        <div style="background:var(--bg);border-radius:12px;padding:16px 20px;border:1px solid var(--border);">
                            <span style="display:block;font-size:0.75rem;color:var(--teal-dark);font-weight:700;text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;">Email</span>
                            <span style="font-family:'Cormorant Garamond',serif;font-size:1.3rem;font-weight:600;">@(r.Email ?? "—")</span>
                        </div>
                        <div style="background:var(--bg);border-radius:12px;padding:16px 20px;border:1px solid var(--border);">
                            <span style="display:block;font-size:0.75rem;color:var(--teal-dark);font-weight:700;text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;">Status</span>
                            <span class="status-badge @(r.Status == "Active" ? "completed" : "pending")">@r.Status</span>
                        </div>
                    </div>
                </div>
            }

        </div>
    </main>
</div>